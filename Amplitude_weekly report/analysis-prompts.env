# 분석용 프롬프트 설정 (프롬프트·모델만 여기서 관리해도 됩니다)
# LLM 키는 프로젝트 루트 .env (예: GEMINI_API_KEY, OPENAI_API_KEY).

ANALYSIS_MODEL=gpt-4o-mini

# PROMPT_JOURNEY_FILE 이 있으면 해당 파일 전체가 여정지도 분석 지시문이 됩니다.
PROMPT_JOURNEY_FILE=prompts/journey-prompt.txt
PROMPT_INSIGHTS_FILE=prompts/insights-prompt.txt

# 인라인 예: PROMPT_JOURNEY=첫줄\\n둘째줄 (파일 지정이 우선)

# MCP 컨텍스트 JSON 경로 (비우면 amplitude_mcp_context.json → 없으면 amplitude_snapshot.json)
# AMPLITUDE_CONTEXT_FILE=amplitude_mcp_context.json
