# OpenAI (generate_analysis.py — 여정지도·시사점 자동 생성 시 필요)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=  # Azure 등 커스텀 엔드포인트일 때만
# ANALYSIS_MODEL=gpt-4o-mini  # 또는 analysis-prompts.env 에서 설정
# Amplitude MCP 컨텍스트 JSON (generate_analysis.py) — 비우면 amplitude_mcp_context.json 우선
# AMPLITUDE_CONTEXT_FILE=amplitude_mcp_context.json
# 제어 패널이 쓰는 프로젝트 ID (amplitude_mcp_context.json 메타)
# AMPLITUDE_PROJECT_ID=343341

# --- Amplitude Dashboard REST (선택) ---
# 키가 있으면 발송 시 REST로 조회. 없으면 send_email.py --mcp + amplitude_snapshot.json(MCP로 채움).
# AMPLITUDE_API_KEY=
# AMPLITUDE_SECRET_KEY=
# 여정·시사점 자동 생성: GEMINI_API_KEY (analysis-prompts.env / .env). AI 생략 시 SKIP_AI_ANALYSIS=1
# AMPLITUDE_API_BASE=https://amplitude.com
# AMPLITUDE_PLATFORM_GROUP_BY=gp:resPathCd
# 선택: 지역 Top3 (비우면 메일의 인기 지역은 스냅샷·대시보드 수동 값)
# AMPLITUDE_REGION_GROUP_BY=gp:cityName
# AMPLITUDE_FUNNEL_CS_SECONDS=86400
# AMPLITUDE_FUNNEL3_CS_SECONDS=86400
# 이벤트/필터 JSON 덮어쓰기 (한 줄 JSON)
# AMPLITUDE_JSON_E_AI_IMAGE=
# AMPLITUDE_JSON_E_CHATAI=
# AMPLITUDE_JSON_E_PKG=

# 로컬 제어 패널 (python control_server.py) 포트
# CONTROL_PANEL_PORT=8765
# Flask 세션 서명 (미리보기·발송 페이지, 비우면 기본 개발용 키)
# FLASK_SECRET_KEY=

# SMTP 설정
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# 발송 계정
SENDER_EMAIL=lhzero@hanatour.com
SENDER_PASSWORD=your-app-password

# 수신 계정 (여러 명이면 콤마로 구분: a@x.com,b@y.com)
RECEIVER_EMAIL=lhzero@hanatour.com

# 메일 제목
MAIL_SUBJECT=[Amplitude] {month}월 {week}째주 AI이미지 주간보고서

# Windows 작업 스케줄러 등록: register-weekly-report-task.ps1 실행 (이 파일의 SCHEDULE_* 를 읽음)

# --- 작업 스케줄러 등록용 (register-weekly-report-task.ps1만 읽음, send_email.py는 무시) ---
# 요일: 영문 Monday … Sunday (또는 Mon, Tue …)
SCHEDULE_DAY_OF_WEEK=Monday
# 시각 24시 HH:mm
SCHEDULE_TIME=09:00
# 작업 스케줄러 작업 이름(비우면 Amplitude-Weekly-AI-Report)
SCHEDULE_TASK_NAME=Amplitude-Weekly-AI-Report
