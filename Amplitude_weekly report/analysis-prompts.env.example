# 분석용 프롬프트 설정 (이 파일을 복사해 analysis-prompts.env 로 저장한 뒤 수정하세요)
# LLM 키·SMTP 등은 프로젝트 루트 .env (예: GEMINI_API_KEY, OPENAI_API_KEY).

# 모델 (비우면 gpt-4o-mini)
ANALYSIS_MODEL=gpt-4o-mini

# 공통 시스템 메시지 (비우면 스크립트 기본값 사용)
# ANALYSIS_SYSTEM=당신은 여행 앱의 Amplitude 데이터를 해석하는 한국어 PM 애널리스트입니다.

# 프롬프트 본문: 아래처럼 "파일 경로"를 쓰는 방식을 권장합니다 (여러 줄 작성 가능).
# 경로는 이 폴더(Amplitude_weekly report) 기준 상대 경로입니다.
PROMPT_JOURNEY_FILE=prompts/journey-prompt.txt
PROMPT_INSIGHTS_FILE=prompts/insights-prompt.txt

# 또는 한 줄로만 쓸 때는 PROMPT_JOURNEY= / PROMPT_INSIGHTS= 에서 \\n 으로 줄바꿈을 표현할 수 있습니다.
# 파일 지정이 있으면 파일 내용이 우선합니다.

# 1 이면 API 호출 없이 종료합니다 (기존 analysis-output.json 유지).
# SKIP_AI_ANALYSIS=0

# 분석에 넣을 JSON 파일 (프로젝트 폴더 기준 상대 경로). 비우면 존재하는 파일 순으로 자동 선택:
#   1) amplitude_mcp_context.json  2) amplitude_snapshot.json (구버전 호환)
# AMPLITUDE_CONTEXT_FILE=amplitude_mcp_context.json
# 구버전 호환: AMPLITUDE_SNAPSHOT_FILE=amplitude_snapshot.json (설정 시 이 파일만 사용)
